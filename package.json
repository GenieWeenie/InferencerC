{
  "name": "win-inferencer-clone",
  "version": "3.0.0",
  "description": "Windows Desktop App for Local LLM Inference",
  "main": "dist/main/index.js",
  "scripts": {
    "dev": "concurrently \"npm run dev:renderer\" \"npm run dev:electron\"",
    "dev:web": "concurrently \"npm run dev:renderer\" \"npm run dev:backend\"",
    "dev:renderer": "vite",
    "dev:backend": "tsc -p tsconfig.node.json && node dist/server/index.js",
    "dev:electron": "wait-on http://localhost:5173 && tsc -p tsconfig.node.json && electron .",
    "build": "tsc -p tsconfig.node.json && vite build",
    "build:win": "npm run build && electron-builder --win",
    "build:mac": "npm run build && electron-builder --mac -c.mac.identity=null",
    "build:mac:signed": "npm run build && electron-builder --mac",
    "release:mac:signed": "npm run build && electron-builder --mac --publish always",
    "build:linux": "npm run build && electron-builder --linux",
    "build:portable": "npm run build && electron-builder --win portable",
    "clean:workspace": "bash ./scripts/dev/clean_workspace.sh",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "qa:smoke:ui": "bash ./scripts/qa/ui_smoke_qa.sh",
    "qa:release:gate": "bash ./scripts/qa/release_gate.sh"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@fontsource/inter": "^5.2.8",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@types/jspdf": "^1.3.3",
    "@types/react-syntax-highlighter": "^15.5.13",
    "body-parser": "^2.2.2",
    "clsx": "^2.1.1",
    "cors": "^2.8.6",
    "docx": "^9.5.1",
    "electron-updater": "^6.7.3",
    "express": "^5.2.1",
    "framer-motion": "^12.29.0",
    "html2canvas": "^1.4.1",
    "jspdf": "^4.0.0",
    "katex": "^0.16.27",
    "lucide-react": "^0.562.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-markdown": "^10.1.0",
    "react-syntax-highlighter": "^16.1.0",
    "react-virtuoso": "^4.18.1",
    "rehype-katex": "^7.0.1",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.4.0",
    "turndown": "^7.2.2",
    "uuid": "^13.0.0",
    "validator": "^13.15.26"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jest": "^29.5.12",
    "@types/node": "^25.0.10",
    "@types/react": "^19.2.9",
    "@types/react-dom": "^19.2.3",
    "@types/turndown": "^5.0.6",
    "@types/uuid": "^10.0.0",
    "@types/validator": "^13.15.10",
    "@vitejs/plugin-react": "^5.1.2",
    "autoprefixer": "^10.4.23",
    "concurrently": "^9.2.1",
    "electron": "^40.0.0",
    "electron-builder": "^26.4.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^30.2.0",
    "postcss": "^8.5.6",
    "supertest": "^7.0.0",
    "tailwindcss": "^3.4.17",
    "ts-jest": "^29.2.5",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "wait-on": "^9.0.3"
  }
}
