{
  "preset": "ts-jest",
  "testEnvironment": "node",
  "roots": [
    "<rootDir>/__tests__",
    "<rootDir>/src"
  ],
  "testMatch": [
    "**/__tests__/**/*.test.ts",
    "**/?(*.)+(spec|test).ts?(x)"
  ],
  "collectCoverageFrom": [
    "src/**/*.{ts,tsx}",
    "!src/**/*.d.ts",
    "!src/main/**/*",
    "!src/renderer/components/**/*",
    "!src/renderer/pages/**/*",
    "!src/renderer/workers/**/*",
    "!src/renderer/App.tsx",
    "!src/renderer/main.tsx"
  ],
  "coverageThreshold": {
    "global": {
      "statements": 50,
      "branches": 40,
      "functions": 50,
      "lines": 50
    }
  },
  "moduleNameMapper": {
    "^@/(.*)$": "<rootDir>/src/$1"
  },
  "transform": {
    "^.+\\.tsx?$": [
      "ts-jest",
      {
        "tsconfig": "tsconfig.json"
      }
    ]
  }
}